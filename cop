#!/usr/bin/env bash
set -euo pipefail

# cop — Credential Operations
#
# A backend-agnostic credential manager. Reads COP_VAULT from the environment
# to determine which vault to operate on. Backend plugins provide the actual
# implementation (1Password, Bitwarden, etc).
#
# Env vars:
#   COP_VAULT              — vault to operate on (required for most commands)
#   COP_BACKEND            — backend provider (default: op)
#   COP_CREDENTIALS_VAULT  — vault storing SA tokens (default: Private)

COP_LIB_DIR="${HOME}/.local/lib/cop"
COP_CONFIG="${HOME}/.config/cop/config"
COP_DEBUG="${COP_DEBUG:-}"

# ---------------------------------------------------------------------------
# Internal helpers
# ---------------------------------------------------------------------------

_debug() {
  [[ -n "$COP_DEBUG" ]] && echo "[cop] $*" >&2 || true
}

_error() {
  echo "cop: $*" >&2
}

_require_vault() {
  if [[ -z "${COP_VAULT:-}" ]]; then
    _error "COP_VAULT is not set — cd into a space directory or export COP_VAULT"
    exit 1
  fi
}

# ---------------------------------------------------------------------------
# Load config and backend
# ---------------------------------------------------------------------------

# Load config file if present
if [[ -f "$COP_CONFIG" ]]; then
  _debug "Loading config from $COP_CONFIG"
  source "$COP_CONFIG"
fi

# Resolve backend (env > config > default)
COP_BACKEND="${COP_BACKEND:-op}"
COP_CREDENTIALS_VAULT="${COP_CREDENTIALS_VAULT:-Private}"

# Load backend plugin
_backend_file="${COP_LIB_DIR}/${COP_BACKEND}.sh"
if [[ ! -f "$_backend_file" ]]; then
  _error "Backend '${COP_BACKEND}' not found at ${_backend_file}"
  _error "Available backends:"
  for f in "${COP_LIB_DIR}"/*.sh; do
    [[ -f "$f" ]] && _error "  $(basename "$f" .sh)"
  done
  exit 1
fi

_debug "Loading backend: ${COP_BACKEND} from ${_backend_file}"
source "$_backend_file"

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_vault() {
  _require_vault
  echo "$COP_VAULT"
}

cmd_env() {
  local ref="${1:-}"
  local var="${2:-}"

  if [[ -z "$ref" ]]; then
    _error "Usage: cop env <service/field> [VAR_NAME]"
    exit 1
  fi

  _require_vault
  _debug "Reading ${ref} from vault ${COP_VAULT}"

  local value
  value=$(_cop_read "$COP_VAULT" "$ref")
  if [[ -z "$value" ]]; then
    _error "Failed to read ${ref} from vault ${COP_VAULT}"
    exit 1
  fi

  if [[ -n "$var" ]]; then
    # When called with VAR_NAME, output an export statement
    # Caller can eval: eval "$(cop env github/token GH_TOKEN)"
    echo "export ${var}='${value}'"
  else
    echo "$value"
  fi
}

cmd_list() {
  _require_vault
  _debug "Listing items in vault ${COP_VAULT}"
  _cop_list "$COP_VAULT"
}

cmd_token() {
  _require_vault
  _debug "Fetching SA token for vault ${COP_VAULT}"

  local token=""
  local keychain_key="cop-sa-token-${COP_VAULT}"

  # Try macOS Keychain first
  if command -v security >/dev/null 2>&1; then
    token=$(security find-generic-password -a "$USER" -s "$keychain_key" -w 2>/dev/null || true)
    if [[ -n "$token" ]]; then
      _debug "SA token found in keychain"
      echo "$token"
      return 0
    fi
  fi

  # Fetch from backend and cache
  token=$(_cop_sa_token "$COP_VAULT" "$COP_CREDENTIALS_VAULT")
  if [[ -z "$token" ]]; then
    _error "Failed to read SA token for vault '${COP_VAULT}'"
    exit 1
  fi

  # Cache in keychain if available
  if command -v security >/dev/null 2>&1; then
    security add-generic-password -a "$USER" -s "$keychain_key" -w "$token" 2>/dev/null || true
    _debug "SA token cached in keychain"
  fi

  echo "$token"
}

cmd_help() {
  cat <<'EOF'
cop — Credential Operations

Usage: cop [--debug] <command> [args...]

Commands:
  vault                         Show current vault name
  env <service/field>           Echo a secret value
  env <service/field> VAR_NAME  Output export statement for eval
  list                          List items in current vault (JSON)
  token                         Get SA token for current vault (keychain cached)
  help                          Show this help

Environment:
  COP_VAULT              Vault to operate on (set via mise/.mise.toml)
  COP_BACKEND            Backend provider (default: op)
  COP_CREDENTIALS_VAULT  Vault storing SA tokens (default: Private)
  COP_DEBUG              Enable debug output (set to any value)
EOF
}

# ---------------------------------------------------------------------------
# Main dispatch
# ---------------------------------------------------------------------------

# Handle --debug flag
if [[ "${1:-}" == "--debug" ]]; then
  COP_DEBUG=1
  shift
fi

command="${1:-help}"
shift 2>/dev/null || true

case "$command" in
  vault) cmd_vault ;;
  env)   cmd_env "$@" ;;
  list)  cmd_list ;;
  token) cmd_token ;;
  help)  cmd_help ;;
  *)
    _error "Unknown command: $command"
    cmd_help
    exit 1
    ;;
esac
