#!/usr/bin/env bash
set -euo pipefail

# pcm — Personal Credentials Manager
#
# A backend-agnostic credential manager. Backend plugins provide the actual
# implementation (1Password, Bitwarden, etc).
#
# Configuration: ~/.config/pcm/vaults.yml
#
# Env var overrides (take precedence over vaults.yml):
#   PCM_VAULT_ROLE_WORKSPACE    — vault for current context (e.g. set via mise)
#   PCM_VAULT_ROLE_PERSONAL     — personal vault
#   PCM_VAULT_ROLE_CREDENTIALS  — vault storing SA tokens

# Resolve install location (follow symlinks to find the repo)
PCM_HOME="$(dirname "$(readlink -f "$0")")"
PCM_VAULTS="${HOME}/.config/pcm/vaults.yml"
PCM_TOOLS="${HOME}/.config/pcm/tools.yml"
PCM_DEBUG="${PCM_DEBUG:-}"

# ---------------------------------------------------------------------------
# Internal helpers
# ---------------------------------------------------------------------------

_debug() {
  [[ -n "$PCM_DEBUG" ]] && echo "[pcm] $*" >&2 || true
}

_error() {
  echo "pcm: $*" >&2
}

_yq() {
  local result
  result=$(yq "$@" 2>/dev/null) || true
  [[ "$result" == "null" ]] && result=""
  echo "$result"
}

_show_role() {
  local label="$1" value="$2" env_var="$3"
  if [[ -n "$value" ]]; then
    printf "%-13s%s\n" "${label}:" "$value"
  else
    printf "%-13s(not set) export %s=<vault_name>\n" "${label}:" "$env_var"
  fi
}

# ---------------------------------------------------------------------------
# Load vaults configuration
# ---------------------------------------------------------------------------

PCM_DEFAULT_BACKEND="op"

if [[ -f "$PCM_VAULTS" ]]; then
  _debug "Loading vaults from $PCM_VAULTS"

  local_default=$(_yq '.defaults.vault_backend' "$PCM_VAULTS")
  [[ -n "$local_default" ]] && PCM_DEFAULT_BACKEND="$local_default"

  local_workspace=$(_yq '.vault_roles.workspace' "$PCM_VAULTS")
  local_personal=$(_yq '.vault_roles.personal' "$PCM_VAULTS")
  local_credentials=$(_yq '.vault_roles.credentials' "$PCM_VAULTS")

  PCM_VAULT_ROLE_WORKSPACE="${PCM_VAULT_ROLE_WORKSPACE:-$local_workspace}"
  PCM_VAULT_ROLE_PERSONAL="${PCM_VAULT_ROLE_PERSONAL:-$local_personal}"
  PCM_VAULT_ROLE_CREDENTIALS="${PCM_VAULT_ROLE_CREDENTIALS:-$local_credentials}"
else
  _debug "No vaults.yml found at $PCM_VAULTS"
  PCM_VAULT_ROLE_WORKSPACE="${PCM_VAULT_ROLE_WORKSPACE:-}"
  PCM_VAULT_ROLE_PERSONAL="${PCM_VAULT_ROLE_PERSONAL:-}"
  PCM_VAULT_ROLE_CREDENTIALS="${PCM_VAULT_ROLE_CREDENTIALS:-}"
fi

# ---------------------------------------------------------------------------
# Backend loading
# ---------------------------------------------------------------------------

_backend_for_vault() {
  local vault_name="$1"
  if [[ -f "$PCM_VAULTS" ]]; then
    local vb
    vb=$(_yq ".vaults.${vault_name}.backend" "$PCM_VAULTS")
    if [[ -n "$vb" ]]; then
      echo "$vb"
      return
    fi
  fi
  echo "$PCM_DEFAULT_BACKEND"
}

_PCM_LOADED_BACKEND=""

_load_backend() {
  local backend="$1"
  if [[ "$backend" == "$_PCM_LOADED_BACKEND" ]]; then
    return 0
  fi

  local backend_file="${PCM_HOME}/lib/${backend}.sh"
  if [[ ! -f "$backend_file" ]]; then
    _error "Backend '${backend}' not found at ${backend_file}"
    _error "Available backends:"
    for f in "${PCM_HOME}"/lib/*.sh; do
      [[ -f "$f" ]] && _error "  $(basename "$f" .sh)"
    done
    exit 1
  fi

  _debug "Loading backend: ${backend} from ${backend_file}"
  source "$backend_file"
  _PCM_LOADED_BACKEND="$backend"
}

_load_backend "$PCM_DEFAULT_BACKEND"

_with_backend() {
  local vault_name="$1"
  local backend
  backend=$(_backend_for_vault "$vault_name")
  _load_backend "$backend"
  echo "$vault_name"
}

# ---------------------------------------------------------------------------
# Vault role resolution
# ---------------------------------------------------------------------------

_require_workspace_vault() {
  if [[ -z "${PCM_VAULT_ROLE_WORKSPACE:-}" ]]; then
    _error "PCM_VAULT_ROLE_WORKSPACE is not set"
    exit 1
  fi
}

_require_personal_vault() {
  if [[ -z "${PCM_VAULT_ROLE_PERSONAL:-}" ]]; then
    _error "PCM_VAULT_ROLE_PERSONAL is not set — configure vault_roles.personal in ${PCM_VAULTS}"
    exit 1
  fi
}

_require_credentials_vault() {
  if [[ -z "${PCM_VAULT_ROLE_CREDENTIALS:-}" ]]; then
    _error "PCM_VAULT_ROLE_CREDENTIALS is not set — configure vault_roles.credentials in ${PCM_VAULTS}"
    exit 1
  fi
}

_resolve_vault() {
  local from="$1"
  local vault_name=""

  case "$from" in
    personal)
      _require_personal_vault
      vault_name="$PCM_VAULT_ROLE_PERSONAL"
      ;;
    workspace)
      _require_workspace_vault
      vault_name="$PCM_VAULT_ROLE_WORKSPACE"
      ;;
    credentials)
      _require_credentials_vault
      vault_name="$PCM_VAULT_ROLE_CREDENTIALS"
      ;;
    *)
      if [[ -z "$from" ]]; then
        _require_workspace_vault
        vault_name="$PCM_VAULT_ROLE_WORKSPACE"
      else
        vault_name="$from"
      fi
      ;;
  esac

  _with_backend "$vault_name"
}

# ---------------------------------------------------------------------------
# pcm vault
# ---------------------------------------------------------------------------

cmd_vault_help() {
  cat <<'EOF'
pcm vault — Vault management

Usage: pcm vault <subcommand> [args...]

Subcommands:
  list                          List configured vaults and roles
  show [name|role]              Show backend details for a vault
  create <n>                 Create vault, service account, and store SA token
    [--permissions PERMS]         SA permissions (default: read_items)
EOF
}

cmd_vault() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    list)   cmd_vault_list ;;
    show)   cmd_vault_show "$@" ;;
    create) cmd_vault_create "$@" ;;
    "")     cmd_vault_help ;;
    *)
      _error "Unknown vault subcommand: $subcmd"
      cmd_vault_help
      exit 1
      ;;
  esac
}

cmd_vault_list() {
  _show_role "workspace"   "${PCM_VAULT_ROLE_WORKSPACE:-}"    "PCM_VAULT_ROLE_WORKSPACE"
  _show_role "personal"    "${PCM_VAULT_ROLE_PERSONAL:-}"     "PCM_VAULT_ROLE_PERSONAL"
  _show_role "credentials" "${PCM_VAULT_ROLE_CREDENTIALS:-}"  "PCM_VAULT_ROLE_CREDENTIALS"
}

cmd_vault_show() {
  local arg="${1:-workspace}"

  local name
  name=$(_resolve_vault "$arg")

  local roles=""
  [[ "${PCM_VAULT_ROLE_WORKSPACE:-}" == "$name" ]] && roles="workspace"
  [[ "${PCM_VAULT_ROLE_PERSONAL:-}" == "$name" ]] && roles="${roles:+${roles}, }personal"
  [[ "${PCM_VAULT_ROLE_CREDENTIALS:-}" == "$name" ]] && roles="${roles:+${roles}, }credentials"

  local backend
  backend=$(_backend_for_vault "$name")

  echo "Name:    ${name}"
  echo "Role:    ${roles:-(none)}"
  echo "Backend: ${backend}"

  _load_backend "$backend"
  _debug "Fetching vault info for ${name}"
  local info
  info=$(_pcm_vault_info "$name" 2>/dev/null) || true

  if [[ -z "$info" ]]; then
    echo "Status:  not found (or not accessible)"
    return 0
  fi

  if command -v jq >/dev/null 2>&1; then
    local vault_id vault_items vault_created
    vault_id=$(echo "$info" | jq -r '.id // empty')
    vault_items=$(echo "$info" | jq -r '.items // empty')
    vault_created=$(echo "$info" | jq -r '.created_at // empty')

    [[ -n "$vault_id" ]] && echo "ID:      ${vault_id}"
    [[ -n "$vault_items" ]] && echo "Items:   ${vault_items}"
    [[ -n "$vault_created" ]] && echo "Created: ${vault_created}"
  else
    echo "Info:    ${info}"
  fi
}

cmd_vault_create() {
  local name="" permissions="read_items"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --permissions) permissions="$2"; shift 2 ;;
      -*)
        _error "Unknown flag: $1"
        _error "Usage: pcm vault create <n> [--permissions PERMS]"
        exit 1
        ;;
      *)
        if [[ -z "$name" ]]; then
          name="$1"; shift
        else
          _error "Unexpected argument: $1"
          exit 1
        fi
        ;;
    esac
  done

  if [[ -z "$name" ]]; then
    _error "Usage: pcm vault create <n> [--permissions PERMS]"
    exit 1
  fi

  _with_backend "$name" >/dev/null

  if _pcm_vault_exists "$name"; then
    echo "Vault '$name' already exists"
    return 0
  fi

  _debug "Creating vault: $name"
  _pcm_create_vault "$name"
  if ! _pcm_vault_exists "$name"; then
    _error "Failed to create vault '$name'"
    exit 1
  fi
  echo "Created vault: $name"

  _debug "Creating service account: ${name}-sa (permissions: ${permissions})"
  local token
  token=$(_pcm_create_sa "$name" "$name" "$permissions")
  if [[ -z "$token" ]]; then
    _error "Failed to create service account for vault '$name'"
    exit 1
  fi
  echo "Created service account: ${name}-sa"

  _require_credentials_vault
  _debug "Storing SA token in ${PCM_VAULT_ROLE_CREDENTIALS} as ${name}-sa-token"
  _pcm_create_item "$PCM_VAULT_ROLE_CREDENTIALS" "${name}-sa-token" "password" \
    "password=${token}"
  echo "Stored SA token: ${name}-sa-token in ${PCM_VAULT_ROLE_CREDENTIALS}"
}

# ---------------------------------------------------------------------------
# pcm get
# ---------------------------------------------------------------------------

cmd_get_help() {
  cat <<'EOF'
pcm get — Read a credential from a vault

Usage: pcm get [flags] <service/field> [VAR_NAME]

  Without VAR_NAME: echoes the value
  With VAR_NAME:    outputs export VAR_NAME='value' (eval-able)

Vault selection:
  (default)           Read from workspace vault
  -w                  Read from workspace vault (explicit)
  -p                  Read from personal vault
  -c                  Read from credentials vault
  --from <vault>      Read from a named vault (workspace, personal, credentials,
                      or a literal vault name)

Examples:
  pcm get github/token                    # from workspace vault
  pcm get -p github/token                 # from personal vault
  pcm get -p github/token GH_TOKEN        # output: export GH_TOKEN='...'
  pcm get --from lgat postgres/url-dev     # from a specific vault
EOF
}

cmd_get() {
  local from="workspace" ref="" var=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -w)     from="workspace"; shift ;;
      -p)     from="personal"; shift ;;
      -c)     from="credentials"; shift ;;
      --from) from="$2"; shift 2 ;;
      -*)
        _error "Unknown flag: $1"
        cmd_get_help
        exit 1
        ;;
      *)
        if [[ -z "$ref" ]]; then
          ref="$1"
        elif [[ -z "$var" ]]; then
          var="$1"
        else
          _error "Unexpected argument: $1"
          cmd_get_help
          exit 1
        fi
        shift
        ;;
    esac
  done

  if [[ -z "$ref" ]]; then
    cmd_get_help
    exit 1
  fi

  local vault
  vault=$(_resolve_vault "$from")

  _debug "Reading ${ref} from vault ${vault} (source: ${from})"

  local value
  value=$(_pcm_read "$vault" "$ref")
  if [[ -z "$value" ]]; then
    _error "Failed to read ${ref} from vault ${vault}"
    exit 1
  fi

  if [[ -n "$var" ]]; then
    echo "export ${var}='${value}'"
  else
    echo "$value"
  fi
}

# ---------------------------------------------------------------------------
# pcm list
# ---------------------------------------------------------------------------

cmd_list() {
  _require_workspace_vault
  local vault
  vault=$(_with_backend "$PCM_VAULT_ROLE_WORKSPACE")
  _debug "Listing items in vault ${vault}"
  _pcm_list "$vault"
}

# ---------------------------------------------------------------------------
# pcm token
# ---------------------------------------------------------------------------

cmd_token_help() {
  cat <<'EOF'
pcm token — SA token management

Usage: pcm token [subcommand]

Subcommands:
  (default)         Get SA token for workspace vault (keychain cached)
  clear [vault]     Clear cached SA token from keychain
  list              List cached SA tokens in keychain
EOF
}

cmd_token() {
  local subcmd="${1:-get}"
  shift 2>/dev/null || true

  case "$subcmd" in
    get)   cmd_token_get ;;
    clear) cmd_token_clear "$@" ;;
    list)  cmd_token_list ;;
    *)
      _error "Unknown token subcommand: $subcmd"
      cmd_token_help
      exit 1
      ;;
  esac
}

cmd_token_get() {
  _require_workspace_vault
  _debug "Fetching SA token for vault ${PCM_VAULT_ROLE_WORKSPACE}"

  local token=""
  local keychain_key="pcm-sa-token-${PCM_VAULT_ROLE_WORKSPACE}"

  if command -v security >/dev/null 2>&1; then
    token=$(security find-generic-password -a "$USER" -s "$keychain_key" -w 2>/dev/null || true)
    if [[ -n "$token" ]]; then
      _debug "SA token found in keychain"
      echo "$token"
      return 0
    fi
  fi

  _require_credentials_vault
  local creds_vault
  creds_vault=$(_with_backend "$PCM_VAULT_ROLE_CREDENTIALS")
  token=$(_pcm_sa_token "$PCM_VAULT_ROLE_WORKSPACE" "$creds_vault")
  if [[ -z "$token" ]]; then
    _error "Failed to read SA token for vault '${PCM_VAULT_ROLE_WORKSPACE}'"
    exit 1
  fi

  if command -v security >/dev/null 2>&1; then
    security add-generic-password -a "$USER" -s "$keychain_key" -w "$token" 2>/dev/null || true
    _debug "SA token cached in keychain"
  fi

  echo "$token"
}

cmd_token_clear() {
  local vault="${1:-${PCM_VAULT_ROLE_WORKSPACE:-}}"

  if [[ -z "$vault" ]]; then
    _error "Usage: pcm token clear [vault]  (or set PCM_VAULT_ROLE_WORKSPACE)"
    exit 1
  fi

  if ! command -v security >/dev/null 2>&1; then
    _error "Keychain not available (macOS only)"
    exit 1
  fi

  local keychain_key="pcm-sa-token-${vault}"
  if security delete-generic-password -a "$USER" -s "$keychain_key" 2>/dev/null; then
    echo "Cleared cached SA token for '${vault}'"
  else
    echo "No cached SA token found for '${vault}'"
  fi
}

cmd_token_list() {
  if ! command -v security >/dev/null 2>&1; then
    _error "Keychain not available (macOS only)"
    exit 1
  fi

  security dump-keychain 2>/dev/null | grep -B5 '"pcm-sa-token-' | grep '"svce"' | \
    sed 's/.*"svce"<blob>="pcm-sa-token-\(.*\)"/  \1/' || true
}

# ---------------------------------------------------------------------------
# pcm tools
# ---------------------------------------------------------------------------

cmd_tools_help() {
  cat <<'EOF'
pcm tools — Tool wrapper configuration

Usage: pcm tools <subcommand>

Subcommands:
  list              List configured tools and their credential mappings
  show <tool>       Show details for a specific tool

Config: ~/.config/pcm/tools.yml
EOF
}

cmd_tools() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    list) cmd_tools_list ;;
    show) cmd_tools_show "$@" ;;
    "")   cmd_tools_help ;;
    *)
      _error "Unknown tools subcommand: $subcmd"
      cmd_tools_help
      exit 1
      ;;
  esac
}

cmd_tools_list() {
  if [[ ! -f "$PCM_TOOLS" ]]; then
    _error "No tools configured — create ${PCM_TOOLS}"
    exit 1
  fi

  local tools
  tools=$(_yq 'keys | .[]' "$PCM_TOOLS")

  if [[ -z "$tools" ]]; then
    echo "No tools configured"
    return 0
  fi

  while IFS= read -r tool; do
    local vault
    vault=$(_yq ".${tool}.vault // \"workspace\"" "$PCM_TOOLS")
    echo "${tool}  (vault: ${vault})"

    local env_keys
    env_keys=$(_yq ".${tool}.environment | keys | .[]" "$PCM_TOOLS")
    while IFS= read -r var_name; do
      [[ -z "$var_name" ]] && continue
      local ref
      ref=$(_yq ".${tool}.environment.${var_name}" "$PCM_TOOLS")
      echo "  ${var_name} <- ${ref}"
    done <<< "$env_keys"
  done <<< "$tools"
}

cmd_tools_show() {
  local tool_name="${1:-}"

  if [[ -z "$tool_name" ]]; then
    _error "Usage: pcm tools show <tool>"
    exit 1
  fi

  if [[ ! -f "$PCM_TOOLS" ]]; then
    _error "No tools configured — create ${PCM_TOOLS}"
    exit 1
  fi

  local vault
  vault=$(_yq ".${tool_name}.vault" "$PCM_TOOLS")

  if [[ -z "$vault" ]]; then
    _error "Tool '${tool_name}' not found in ${PCM_TOOLS}"
    exit 1
  fi

  local resolved_vault
  resolved_vault=$(_resolve_vault "$vault" 2>/dev/null) || resolved_vault="(unset)"

  echo "Tool: ${tool_name}"
  echo "Vault: ${vault} (${resolved_vault})"
  echo "Environment:"

  local env_keys
  env_keys=$(_yq ".${tool_name}.environment | keys | .[]" "$PCM_TOOLS")
  while IFS= read -r var_name; do
    [[ -z "$var_name" ]] && continue
    local ref
    ref=$(_yq ".${tool_name}.environment.${var_name}" "$PCM_TOOLS")
    echo "  ${var_name} <- ${ref}"
  done <<< "$env_keys"
}

# ---------------------------------------------------------------------------
# pcm remote-env
# ---------------------------------------------------------------------------

cmd_remote_env() {
  _require_workspace_vault

  local vault
  vault=$(_with_backend "$PCM_VAULT_ROLE_WORKSPACE")
  _debug "Generating remote env for vault ${vault} (backend: $(_backend_for_vault "$vault"))"

  _require_credentials_vault
  local env_output
  env_output=$(_pcm_remote_env "$vault" "$PCM_VAULT_ROLE_CREDENTIALS")
  if [[ -z "$env_output" ]]; then
    _error "Failed to generate remote env for vault '${vault}'"
    exit 1
  fi

  echo "$env_output"
}

# ---------------------------------------------------------------------------
# pcm update
# ---------------------------------------------------------------------------

cmd_update() {
  _debug "Updating pcm from ${PCM_HOME}"
  if [[ ! -d "${PCM_HOME}/.git" ]]; then
    _error "PCM_HOME (${PCM_HOME}) is not a git repo — cannot update"
    exit 1
  fi
  git -C "$PCM_HOME" pull
  echo "pcm updated"
}

# ---------------------------------------------------------------------------
# pcm help
# ---------------------------------------------------------------------------

cmd_help() {
  cat <<'EOF'
pcm — Personal Credentials Manager

Usage: pcm [--debug] <command> [args...]

Commands:
  get [flags] <ref> [VAR]       Read a credential from a vault
    -w                            from workspace vault
    -p                            from personal vault
    -c                            from credentials vault
    --from <vault>                from a named vault
  vault                         Vault management (list, show, create)
  list                          List items in workspace vault (JSON)
  token                         SA token management (get, clear, list)
  tools                         Tool wrapper configuration (list, show)
  remote-env                    Output backend-specific env exports for remote hosts
  update                        Update pcm (git pull)
  help                          Show this help

Configuration:
  ~/.config/pcm/vaults.yml        Vault backends, roles, and registry
  ~/.config/pcm/tools.yml         Tool wrapper credential mappings

Env var overrides:
  PCM_VAULT_ROLE_WORKSPACE    Override workspace vault role
  PCM_VAULT_ROLE_PERSONAL     Override personal vault role
  PCM_VAULT_ROLE_CREDENTIALS  Override credentials vault role
  PCM_DEBUG                   Enable debug output (set to any value)

Run 'pcm <command>' for subcommand help.
EOF
}

# ---------------------------------------------------------------------------
# Main dispatch
# ---------------------------------------------------------------------------

if [[ "${1:-}" == "--debug" ]]; then
  PCM_DEBUG=1
  shift
fi

command="${1:-help}"
shift 2>/dev/null || true

case "$command" in
  get)        cmd_get "$@" ;;
  vault)      cmd_vault "$@" ;;
  list)       cmd_list ;;
  token)      cmd_token "$@" ;;
  tools)      cmd_tools "$@" ;;
  remote-env) cmd_remote_env ;;
  update)     cmd_update ;;
  help)       cmd_help ;;
  *)
    _error "Unknown command: $command"
    cmd_help
    exit 1
    ;;
esac
