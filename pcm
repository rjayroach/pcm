#!/usr/bin/env bash
set -euo pipefail

# pcm — Personal Credentials Manager
#
# A backend-agnostic credential manager. Backend plugins provide the actual
# implementation (1Password, Bitwarden, etc).
#
# Configuration (unified .pcm.yml schema, merged in order):
#   1. ~/.config/pcm/conf.d/*.yml    — global fragments (alphabetical)
#   2. Walk up from $PWD: .pcm.yml   — project/space-local overrides
#
# Env var overrides (take precedence over config):
#   PCM_VAULT_ROLE_WORKSPACE    — vault for current context (e.g. set via mise)
#   PCM_VAULT_ROLE_PERSONAL     — personal vault
#   PCM_VAULT_ROLE_CREDENTIALS  — vault storing SA tokens

# Resolve install location (follow symlinks to find the repo)
PCM_HOME="$(dirname "$(readlink -f "$0")")"
PCM_CONF_DIR="${HOME}/.config/pcm/conf.d"

# Parse --debug early so config loading can use it
PCM_DEBUG="${PCM_DEBUG:-}"
if [[ "${1:-}" == "--debug" ]]; then
  PCM_DEBUG=1
  shift
fi
_PCM_ARGS=("$@")

# ---------------------------------------------------------------------------
# Internal helpers
# ---------------------------------------------------------------------------

_debug() {
  [[ -n "$PCM_DEBUG" ]] && echo "[pcm] $*" >&2 || true
}

_error() {
  echo "pcm: $*" >&2
}

_yq() {
  local result
  result=$(yq "$@" 2>/dev/null) || true
  [[ "$result" == "null" ]] && result=""
  echo "$result"
}

_show_role() {
  local label="$1" value="$2" env_var="$3"
  if [[ -n "$value" ]]; then
    printf "%-13s%s\n" "${label}:" "$value"
  else
    printf "%-13s(not set) export %s=<vault_name>\n" "${label}:" "$env_var"
  fi
}

# ---------------------------------------------------------------------------
# Unified config loading
# ---------------------------------------------------------------------------
# PCM uses a merged config model. All config files share the same schema:
#
#   defaults:
#     backend: op
#   vaults:
#     my-vault:
#   roles:
#     personal: my-vault
#   settings:
#     prefix: ${PCM_SITE}
#     separator: "-"
#   credentials:
#     gh:
#       vault: personal
#       fields:
#         GH_TOKEN: token
#
# Files are merged in order (later wins):
#   1. ~/.config/pcm/conf.d/*.yml (alphabetical)
#   2. .pcm.yml files walking up from $PWD (outermost first, innermost last)
#
# Additionally, legacy files are supported during migration:
#   - ~/.config/pcm/vaults.yml  (old vault config)
#   - ~/.config/pcm/tools.yml   (old tool config)

# Merged config is built as a temp file that yq can query
_PCM_CONFIG=""

_build_config() {
  local tmpfile
  tmpfile=$(mktemp /tmp/pcm-config.XXXXXX.yml)
  echo "{}" > "$tmpfile"

  # --- Legacy support: migrate old vaults.yml schema on the fly ---
  local legacy_vaults="${HOME}/.config/pcm/vaults.yml"
  if [[ -f "$legacy_vaults" ]]; then
    _debug "Loading legacy vaults.yml from $legacy_vaults"
    # Transform old schema to new:
    #   defaults.vault_backend → defaults.backend
    #   vault_roles → roles
    local legacy_tmp
    legacy_tmp=$(mktemp /tmp/pcm-legacy.XXXXXX.yml)
    yq '
      {
        "defaults": {"backend": (.defaults.vault_backend // "op")},
        "vaults": .vaults,
        "roles": .vault_roles
      } | with_entries(select(.value != null))
    ' "$legacy_vaults" > "$legacy_tmp" 2>/dev/null || true
    yq -i '. *d load("'"$legacy_tmp"'")' "$tmpfile" 2>/dev/null || true
    rm -f "$legacy_tmp"
  fi

  # --- Legacy support: migrate old tools.yml schema on the fly ---
  local legacy_tools="${HOME}/.config/pcm/tools.yml"
  if [[ -f "$legacy_tools" ]] && [[ ! -d "$PCM_CONF_DIR" || -z "$(ls -A "$PCM_CONF_DIR" 2>/dev/null)" ]]; then
    _debug "Loading legacy tools.yml from $legacy_tools"
    # Transform: top-level keys with .vault and .environment → credentials with .vault and .fields
    local tools_tmp
    tools_tmp=$(mktemp /tmp/pcm-tools.XXXXXX.yml)
    yq '{"credentials": (to_entries | map(.value = {"vault": .value.vault, "fields": .value.environment}) | from_entries)}' \
      "$legacy_tools" > "$tools_tmp" 2>/dev/null || true
    yq -i '. *d load("'"$tools_tmp"'")' "$tmpfile" 2>/dev/null || true
    rm -f "$tools_tmp"
  fi

  # --- Phase 1: Load global conf.d fragments ---
  if [[ -d "$PCM_CONF_DIR" ]]; then
    for f in "$PCM_CONF_DIR"/*.yml; do
      [[ -f "$f" ]] || continue
      _debug "Loading conf.d: $f"
      yq -i '. *d load("'"$f"'")' "$tmpfile" 2>/dev/null || true
    done
  fi

  # --- Phase 2: Walk up from $PWD collecting .pcm.yml / pcm.yml files ---
  # Supports both hidden (.pcm.yml) and non-hidden (pcm.yml), like mise.
  # If both exist in the same directory, only .pcm.yml is used.
  local -a pcm_files=()
  local dir="$PWD"

  while [[ "$dir" != "/" ]]; do
    if [[ -f "${dir}/.pcm.yml" ]]; then
      pcm_files+=("${dir}/.pcm.yml")
    elif [[ -f "${dir}/pcm.yml" ]]; then
      pcm_files+=("${dir}/pcm.yml")
    fi
    dir="$(dirname "$dir")"
  done

  # Merge outermost first so innermost wins
  local i
  for (( i=${#pcm_files[@]}-1; i>=0; i-- )); do
    _debug "Loading project config: ${pcm_files[$i]}"
    yq -i '. *d load("'"${pcm_files[$i]}"'")' "$tmpfile" 2>/dev/null || true
  done

  _PCM_CONFIG="$tmpfile"
  _debug "Effective config: $tmpfile"
}

_build_config

_cfg() {
  _yq "$@" "$_PCM_CONFIG"
}

# Cleanup temp config on exit
trap 'rm -f "$_PCM_CONFIG"' EXIT

# ---------------------------------------------------------------------------
# Read config values
# ---------------------------------------------------------------------------

PCM_DEFAULT_BACKEND=$(_cfg '.defaults.backend // "op"')

_cfg_workspace=$(_cfg '.roles.workspace')
_cfg_personal=$(_cfg '.roles.personal')
_cfg_credentials=$(_cfg '.roles.credentials')

PCM_VAULT_ROLE_WORKSPACE="${PCM_VAULT_ROLE_WORKSPACE:-$_cfg_workspace}"
PCM_VAULT_ROLE_PERSONAL="${PCM_VAULT_ROLE_PERSONAL:-$_cfg_personal}"
PCM_VAULT_ROLE_CREDENTIALS="${PCM_VAULT_ROLE_CREDENTIALS:-$_cfg_credentials}"

# Settings (from merged config — project-local overrides global)
_PCM_SETTINGS_PREFIX=$(_cfg '.settings.prefix')
_PCM_SETTINGS_SEPARATOR=$(_cfg '.settings.separator // "-"')

# ---------------------------------------------------------------------------
# Prefix resolution
# ---------------------------------------------------------------------------

# Resolve a prefix template string by expanding ${VAR} references.
# If settings.prefix is declared, all referenced env vars must be set.
# If settings.prefix is not declared, returns empty string.
_resolve_prefix() {
  if [[ -z "$_PCM_SETTINGS_PREFIX" ]]; then
    echo ""
    return 0
  fi

  local prefix="$_PCM_SETTINGS_PREFIX"
  local resolved="$prefix"

  # Extract all ${VAR} references and validate they're set
  local var_names
  var_names=$(echo "$prefix" | grep -oE '\$\{[A-Za-z_][A-Za-z0-9_]*\}' | sed 's/\${\(.*\)}/\1/' | sort -u)

  while IFS= read -r var; do
    [[ -z "$var" ]] && continue
    local val="${!var:-}"
    if [[ -z "$val" ]]; then
      _error "Prefix variable ${var} is not set (required by settings.prefix: ${prefix})"
      exit 1
    fi
    resolved="${resolved//\$\{${var}\}/${val}}"
  done <<< "$var_names"

  echo "$resolved"
}

# Build the full item ref: [prefix-]<credential_name>/<field_name>
_build_ref() {
  local cred_name="$1" field_name="$2"
  local prefix
  prefix=$(_resolve_prefix)

  if [[ -n "$prefix" ]]; then
    echo "${prefix}${_PCM_SETTINGS_SEPARATOR}${cred_name}/${field_name}"
  else
    echo "${cred_name}/${field_name}"
  fi
}

# ---------------------------------------------------------------------------
# Backend loading
# ---------------------------------------------------------------------------

_backend_for_vault() {
  local vault_name="$1"
  local vb
  vb=$(_cfg ".vaults.${vault_name}.backend")
  if [[ -n "$vb" ]]; then
    echo "$vb"
    return
  fi
  echo "$PCM_DEFAULT_BACKEND"
}

_PCM_LOADED_BACKEND=""

_load_backend() {
  local backend="$1"
  if [[ "$backend" == "$_PCM_LOADED_BACKEND" ]]; then
    return 0
  fi

  local backend_file="${PCM_HOME}/lib/${backend}.sh"
  if [[ ! -f "$backend_file" ]]; then
    _error "Backend '${backend}' not found at ${backend_file}"
    _error "Available backends:"
    for f in "${PCM_HOME}"/lib/*.sh; do
      [[ -f "$f" ]] && _error "  $(basename "$f" .sh)"
    done
    exit 1
  fi

  _debug "Loading backend: ${backend} from ${backend_file}"
  source "$backend_file"
  _PCM_LOADED_BACKEND="$backend"
}

_load_backend "$PCM_DEFAULT_BACKEND"

_with_backend() {
  local vault_name="$1"
  local backend
  backend=$(_backend_for_vault "$vault_name")
  _load_backend "$backend"
  echo "$vault_name"
}

# ---------------------------------------------------------------------------
# Vault role resolution
# ---------------------------------------------------------------------------

_require_workspace_vault() {
  if [[ -z "${PCM_VAULT_ROLE_WORKSPACE:-}" ]]; then
    _error "PCM_VAULT_ROLE_WORKSPACE is not set"
    exit 1
  fi
}

_require_personal_vault() {
  if [[ -z "${PCM_VAULT_ROLE_PERSONAL:-}" ]]; then
    _error "PCM_VAULT_ROLE_PERSONAL is not set — configure roles.personal in a .pcm.yml"
    exit 1
  fi
}

_require_credentials_vault() {
  if [[ -z "${PCM_VAULT_ROLE_CREDENTIALS:-}" ]]; then
    _error "PCM_VAULT_ROLE_CREDENTIALS is not set — configure roles.credentials in a .pcm.yml"
    exit 1
  fi
}

_resolve_vault() {
  local from="$1"
  local vault_name=""

  case "$from" in
    personal)
      _require_personal_vault
      vault_name="$PCM_VAULT_ROLE_PERSONAL"
      ;;
    workspace)
      _require_workspace_vault
      vault_name="$PCM_VAULT_ROLE_WORKSPACE"
      ;;
    credentials)
      _require_credentials_vault
      vault_name="$PCM_VAULT_ROLE_CREDENTIALS"
      ;;
    *)
      if [[ -z "$from" ]]; then
        _require_workspace_vault
        vault_name="$PCM_VAULT_ROLE_WORKSPACE"
      else
        vault_name="$from"
      fi
      ;;
  esac

  _with_backend "$vault_name"
}

# ---------------------------------------------------------------------------
# pcm vault
# ---------------------------------------------------------------------------

cmd_vault_help() {
  cat <<'EOF'
pcm vault — Vault management

Usage: pcm vault <subcommand> [args...]

Subcommands:
  list                          List configured vaults and roles
  show [name|role]              Show backend details for a vault
  create <name>                 Create vault, service account, and store SA token
    [--permissions PERMS]         SA permissions (default: read_items)
EOF
}

cmd_vault() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    list)   cmd_vault_list ;;
    show)   cmd_vault_show "$@" ;;
    create) cmd_vault_create "$@" ;;
    "")     cmd_vault_help ;;
    *)
      _error "Unknown vault subcommand: $subcmd"
      cmd_vault_help
      exit 1
      ;;
  esac
}

cmd_vault_list() {
  _show_role "workspace"   "${PCM_VAULT_ROLE_WORKSPACE:-}"    "PCM_VAULT_ROLE_WORKSPACE"
  _show_role "personal"    "${PCM_VAULT_ROLE_PERSONAL:-}"     "PCM_VAULT_ROLE_PERSONAL"
  _show_role "credentials" "${PCM_VAULT_ROLE_CREDENTIALS:-}"  "PCM_VAULT_ROLE_CREDENTIALS"
}

cmd_vault_show() {
  local arg="${1:-workspace}"

  local name
  name=$(_resolve_vault "$arg")

  local roles=""
  [[ "${PCM_VAULT_ROLE_WORKSPACE:-}" == "$name" ]] && roles="workspace"
  [[ "${PCM_VAULT_ROLE_PERSONAL:-}" == "$name" ]] && roles="${roles:+${roles}, }personal"
  [[ "${PCM_VAULT_ROLE_CREDENTIALS:-}" == "$name" ]] && roles="${roles:+${roles}, }credentials"

  local backend
  backend=$(_backend_for_vault "$name")

  echo "Name:    ${name}"
  echo "Role:    ${roles:-(none)}"
  echo "Backend: ${backend}"

  _load_backend "$backend"
  _debug "Fetching vault info for ${name}"
  local info
  info=$(_pcm_vault_info "$name" 2>/dev/null) || true

  if [[ -z "$info" ]]; then
    echo "Status:  not found (or not accessible)"
    return 0
  fi

  if command -v jq >/dev/null 2>&1; then
    local vault_id vault_items vault_created
    vault_id=$(echo "$info" | jq -r '.id // empty')
    vault_items=$(echo "$info" | jq -r '.items // empty')
    vault_created=$(echo "$info" | jq -r '.created_at // empty')

    [[ -n "$vault_id" ]] && echo "ID:      ${vault_id}"
    [[ -n "$vault_items" ]] && echo "Items:   ${vault_items}"
    [[ -n "$vault_created" ]] && echo "Created: ${vault_created}"
  else
    echo "Info:    ${info}"
  fi
}

cmd_vault_create() {
  local name="" permissions="read_items"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --permissions) permissions="$2"; shift 2 ;;
      -*)
        _error "Unknown flag: $1"
        _error "Usage: pcm vault create <name> [--permissions PERMS]"
        exit 1
        ;;
      *)
        if [[ -z "$name" ]]; then
          name="$1"; shift
        else
          _error "Unexpected argument: $1"
          exit 1
        fi
        ;;
    esac
  done

  if [[ -z "$name" ]]; then
    _error "Usage: pcm vault create <name> [--permissions PERMS]"
    exit 1
  fi

  _with_backend "$name" >/dev/null

  if _pcm_vault_exists "$name"; then
    echo "Vault '$name' already exists"
    return 0
  fi

  _debug "Creating vault: $name"
  _pcm_create_vault "$name"
  if ! _pcm_vault_exists "$name"; then
    _error "Failed to create vault '$name'"
    exit 1
  fi
  echo "Created vault: $name"

  _debug "Creating service account: ${name}-sa (permissions: ${permissions})"
  local token
  token=$(_pcm_create_sa "$name" "$name" "$permissions")
  if [[ -z "$token" ]]; then
    _error "Failed to create service account for vault '$name'"
    exit 1
  fi
  echo "Created service account: ${name}-sa"

  _require_credentials_vault
  _debug "Storing SA token in ${PCM_VAULT_ROLE_CREDENTIALS} as ${name}-sa-token"
  _pcm_create_item "$PCM_VAULT_ROLE_CREDENTIALS" "${name}-sa-token" "password" \
    "password=${token}"
  echo "Stored SA token: ${name}-sa-token in ${PCM_VAULT_ROLE_CREDENTIALS}"
}

# ---------------------------------------------------------------------------
# pcm get
# ---------------------------------------------------------------------------

cmd_get_help() {
  cat <<'EOF'
pcm get — Read credentials from a vault

Usage: pcm get [flags] <ref> [VAR_NAME]
       pcm get <credential>

  ref = item/field         Read a single field value
                             If item matches a configured credential, prefix is applied
                             and vault is resolved from config
  credential = name        Read all fields for a credential (from .pcm.yml)
    (no slash)               Outputs export lines for all env vars

  Without VAR_NAME: echoes the value
  With VAR_NAME:    outputs export VAR_NAME='value' (eval-able)
  Credential mode:  always outputs export lines for all env vars

Vault selection (ref mode only — credential mode uses configured vault):
  (default)           Read from workspace vault
  -w                  Read from workspace vault (explicit)
  -p                  Read from personal vault
  -c                  Read from credentials vault
  --from <vault>      Read from a named vault or role

Examples:
  pcm get unifi/credential                # direct ref from workspace (no prefix)
  pcm get -p github/token                 # direct ref from personal vault
  pcm get -p github/token GH_TOKEN        # output: export GH_TOKEN='...'
  pcm get --from lgat postgres/url-dev    # from a specific vault
  pcm get gh                              # all fields for gh credential
  pcm get unifi                           # all fields for unifi (with prefix)
  eval $(pcm get aws)                     # load aws credentials into shell
EOF
}

_get_credential_env() {
  local cred_name="$1"

  local cred_vault
  cred_vault=$(_cfg ".credentials.${cred_name}.vault")
  if [[ -z "$cred_vault" ]]; then
    return 1
  fi

  local vault
  vault=$(_resolve_vault "$cred_vault")

  _debug "Loading credential '${cred_name}' from vault ${vault} (role: ${cred_vault})"

  local field_keys
  field_keys=$(_cfg ".credentials.${cred_name}.fields | keys | .[]")

  local had_error=0
  while IFS= read -r var_name; do
    [[ -z "$var_name" ]] && continue
    local field_name ref value
    field_name=$(_cfg ".credentials.${cred_name}.fields.${var_name}")
    ref=$(_build_ref "$cred_name" "$field_name")
    _debug "  ${var_name} <- ${ref}"
    value=$(_pcm_read "$vault" "$ref")
    if [[ -z "$value" ]]; then
      _error "Failed to read ${ref} from vault ${vault} (credential: ${cred_name}, var: ${var_name})"
      had_error=1
      continue
    fi
    echo "export ${var_name}='${value}'"
  done <<< "$field_keys"

  return $had_error
}

cmd_get() {
  local from="workspace" ref="" var=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -w)     from="workspace"; shift ;;
      -p)     from="personal"; shift ;;
      -c)     from="credentials"; shift ;;
      --from) from="$2"; shift 2 ;;
      -*)
        _error "Unknown flag: $1"
        cmd_get_help
        exit 1
        ;;
      *)
        if [[ -z "$ref" ]]; then
          ref="$1"
        elif [[ -z "$var" ]]; then
          var="$1"
        else
          _error "Unexpected argument: $1"
          cmd_get_help
          exit 1
        fi
        shift
        ;;
    esac
  done

  if [[ -z "$ref" ]]; then
    cmd_get_help
    exit 1
  fi

  # Credential mode: no slash means look up in credentials config
  if [[ "$ref" != */* ]]; then
    if _get_credential_env "$ref"; then
      return 0
    else
      _error "'${ref}' is not a configured credential and not a valid ref (expected item/field)"
      exit 1
    fi
  fi

  # Ref mode: item/field
  # If the item name matches a configured credential, apply prefix and use its vault
  local item_name="${ref%%/*}"
  local field_name="${ref#*/}"
  local vault

  local cred_vault
  cred_vault=$(_cfg ".credentials.${item_name}.vault")
  if [[ -n "$cred_vault" ]]; then
    # Known credential — apply prefix and use configured vault
    ref=$(_build_ref "$item_name" "$field_name")
    vault=$(_resolve_vault "$cred_vault")
    _debug "Reading ${ref} from vault ${vault} (credential: ${item_name}, field: ${field_name})"
  else
    # Unknown credential — use ref as-is with specified vault
    vault=$(_resolve_vault "$from")
    _debug "Reading ${ref} from vault ${vault} (source: ${from})"
  fi

  local value
  value=$(_pcm_read "$vault" "$ref")
  if [[ -z "$value" ]]; then
    _error "Failed to read ${ref} from vault ${vault}"
    exit 1
  fi

  if [[ -n "$var" ]]; then
    echo "export ${var}='${value}'"
  else
    echo "$value"
  fi
}

# ---------------------------------------------------------------------------
# pcm list
# ---------------------------------------------------------------------------

cmd_list() {
  _require_workspace_vault
  local vault
  vault=$(_with_backend "$PCM_VAULT_ROLE_WORKSPACE")
  _debug "Listing items in vault ${vault}"
  _pcm_list "$vault"
}

# ---------------------------------------------------------------------------
# pcm token
# ---------------------------------------------------------------------------

cmd_token_help() {
  cat <<'EOF'
pcm token — SA token management

Usage: pcm token [subcommand]

Subcommands:
  (default)         Get SA token for workspace vault (keychain cached)
  clear [vault]     Clear cached SA token from keychain
  list              List cached SA tokens in keychain
EOF
}

cmd_token() {
  local subcmd="${1:-get}"
  shift 2>/dev/null || true

  case "$subcmd" in
    get)   cmd_token_get ;;
    clear) cmd_token_clear "$@" ;;
    list)  cmd_token_list ;;
    *)
      _error "Unknown token subcommand: $subcmd"
      cmd_token_help
      exit 1
      ;;
  esac
}

cmd_token_get() {
  _require_workspace_vault
  _debug "Fetching SA token for vault ${PCM_VAULT_ROLE_WORKSPACE}"

  local token=""
  local keychain_key="pcm-sa-token-${PCM_VAULT_ROLE_WORKSPACE}"

  if command -v security >/dev/null 2>&1; then
    token=$(security find-generic-password -a "$USER" -s "$keychain_key" -w 2>/dev/null || true)
    if [[ -n "$token" ]]; then
      _debug "SA token found in keychain"
      echo "$token"
      return 0
    fi
  fi

  _require_credentials_vault
  local creds_vault
  creds_vault=$(_with_backend "$PCM_VAULT_ROLE_CREDENTIALS")
  token=$(_pcm_sa_token "$PCM_VAULT_ROLE_WORKSPACE" "$creds_vault")
  if [[ -z "$token" ]]; then
    _error "Failed to read SA token for vault '${PCM_VAULT_ROLE_WORKSPACE}'"
    exit 1
  fi

  if command -v security >/dev/null 2>&1; then
    security add-generic-password -a "$USER" -s "$keychain_key" -w "$token" 2>/dev/null || true
    _debug "SA token cached in keychain"
  fi

  echo "$token"
}

cmd_token_clear() {
  local vault="${1:-${PCM_VAULT_ROLE_WORKSPACE:-}}"

  if [[ -z "$vault" ]]; then
    _error "Usage: pcm token clear [vault]  (or set PCM_VAULT_ROLE_WORKSPACE)"
    exit 1
  fi

  if ! command -v security >/dev/null 2>&1; then
    _error "Keychain not available (macOS only)"
    exit 1
  fi

  local keychain_key="pcm-sa-token-${vault}"
  if security delete-generic-password -a "$USER" -s "$keychain_key" 2>/dev/null; then
    echo "Cleared cached SA token for '${vault}'"
  else
    echo "No cached SA token found for '${vault}'"
  fi
}

cmd_token_list() {
  if ! command -v security >/dev/null 2>&1; then
    _error "Keychain not available (macOS only)"
    exit 1
  fi

  security dump-keychain 2>/dev/null | grep -B5 '"pcm-sa-token-' | grep '"svce"' | \
    sed 's/.*"svce"<blob>="pcm-sa-token-\(.*\)"/  \1/' || true
}

# ---------------------------------------------------------------------------
# pcm credentials (replaces pcm tools)
# ---------------------------------------------------------------------------

cmd_credentials_help() {
  cat <<'EOF'
pcm credentials — Credential configuration

Usage: pcm credentials <subcommand>

Subcommands:
  list              List configured credentials and their field mappings
  show <name>       Show details for a specific credential

Config loaded from: ~/.config/pcm/conf.d/*.yml and .pcm.yml (walked up from $PWD)
EOF
}

cmd_credentials() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    list) cmd_credentials_list ;;
    show) cmd_credentials_show "$@" ;;
    "")   cmd_credentials_help ;;
    *)
      _error "Unknown credentials subcommand: $subcmd"
      cmd_credentials_help
      exit 1
      ;;
  esac
}

cmd_credentials_list() {
  local creds
  creds=$(_cfg '.credentials | keys | .[]')

  if [[ -z "$creds" ]]; then
    echo "No credentials configured"
    return 0
  fi

  local prefix
  prefix=$(_resolve_prefix 2>/dev/null) || prefix=""

  while IFS= read -r cred; do
    local vault
    vault=$(_cfg ".credentials.${cred}.vault // \"workspace\"")
    if [[ -n "$prefix" ]]; then
      echo "${cred}  (vault: ${vault}, item: ${prefix}${_PCM_SETTINGS_SEPARATOR}${cred})"
    else
      echo "${cred}  (vault: ${vault})"
    fi

    local field_keys
    field_keys=$(_cfg ".credentials.${cred}.fields | keys | .[]")
    while IFS= read -r var_name; do
      [[ -z "$var_name" ]] && continue
      local field_name
      field_name=$(_cfg ".credentials.${cred}.fields.${var_name}")
      echo "  ${var_name} <- ${field_name}"
    done <<< "$field_keys"
  done <<< "$creds"
}

cmd_credentials_show() {
  local cred_name="${1:-}"

  if [[ -z "$cred_name" ]]; then
    _error "Usage: pcm credentials show <name>"
    exit 1
  fi

  local vault
  vault=$(_cfg ".credentials.${cred_name}.vault")

  if [[ -z "$vault" ]]; then
    _error "Credential '${cred_name}' not found in config"
    exit 1
  fi

  local resolved_vault
  resolved_vault=$(_resolve_vault "$vault" 2>/dev/null) || resolved_vault="(unset)"

  local prefix
  prefix=$(_resolve_prefix 2>/dev/null) || prefix=""

  echo "Credential: ${cred_name}"
  echo "Vault:      ${vault} (${resolved_vault})"
  if [[ -n "$prefix" ]]; then
    echo "Item:       ${prefix}${_PCM_SETTINGS_SEPARATOR}${cred_name}"
  else
    echo "Item:       ${cred_name}"
  fi
  echo "Fields:"

  local field_keys
  field_keys=$(_cfg ".credentials.${cred_name}.fields | keys | .[]")
  while IFS= read -r var_name; do
    [[ -z "$var_name" ]] && continue
    local field_name ref
    field_name=$(_cfg ".credentials.${cred_name}.fields.${var_name}")
    if [[ -n "$prefix" ]]; then
      ref="${prefix}${_PCM_SETTINGS_SEPARATOR}${cred_name}/${field_name}"
    else
      ref="${cred_name}/${field_name}"
    fi
    echo "  ${var_name} <- ${ref}"
  done <<< "$field_keys"
}

# ---------------------------------------------------------------------------
# pcm config (diagnostic)
# ---------------------------------------------------------------------------

cmd_config() {
  echo "Effective configuration:"
  echo ""
  echo "Sources (merge order):"

  # Show global conf.d
  if [[ -d "$PCM_CONF_DIR" ]]; then
    for f in "$PCM_CONF_DIR"/*.yml; do
      [[ -f "$f" ]] && echo "  $f"
    done
  fi

  # Show legacy files if present
  [[ -f "${HOME}/.config/pcm/vaults.yml" ]] && echo "  ${HOME}/.config/pcm/vaults.yml (legacy)"
  [[ -f "${HOME}/.config/pcm/tools.yml" ]] && echo "  ${HOME}/.config/pcm/tools.yml (legacy)"

  # Show walked-up .pcm.yml / pcm.yml files
  local dir="$PWD"
  local -a pcm_files=()
  while [[ "$dir" != "/" ]]; do
    if [[ -f "${dir}/.pcm.yml" ]]; then
      pcm_files+=("${dir}/.pcm.yml")
    elif [[ -f "${dir}/pcm.yml" ]]; then
      pcm_files+=("${dir}/pcm.yml")
    fi
    dir="$(dirname "$dir")"
  done
  for (( i=${#pcm_files[@]}-1; i>=0; i-- )); do
    echo "  ${pcm_files[$i]}"
  done

  echo ""
  echo "Resolved values:"
  echo "  backend:    ${PCM_DEFAULT_BACKEND}"
  _show_role "workspace"   "${PCM_VAULT_ROLE_WORKSPACE:-}"    "PCM_VAULT_ROLE_WORKSPACE"
  _show_role "personal"    "${PCM_VAULT_ROLE_PERSONAL:-}"     "PCM_VAULT_ROLE_PERSONAL"
  _show_role "credentials" "${PCM_VAULT_ROLE_CREDENTIALS:-}"  "PCM_VAULT_ROLE_CREDENTIALS"

  if [[ -n "$_PCM_SETTINGS_PREFIX" ]]; then
    local prefix
    prefix=$(_resolve_prefix 2>/dev/null) || prefix="(unresolvable)"
    echo "  prefix:     ${_PCM_SETTINGS_PREFIX} → ${prefix}"
    echo "  separator:  ${_PCM_SETTINGS_SEPARATOR}"
  fi

  local cred_count
  cred_count=$(_cfg '.credentials | length')
  echo "  credentials: ${cred_count:-0} configured"
}

# ---------------------------------------------------------------------------
# pcm remote-env
# ---------------------------------------------------------------------------

cmd_remote_env() {
  _require_workspace_vault

  local vault
  vault=$(_with_backend "$PCM_VAULT_ROLE_WORKSPACE")
  _debug "Generating remote env for vault ${vault} (backend: $(_backend_for_vault "$vault"))"

  _require_credentials_vault
  local env_output
  env_output=$(_pcm_remote_env "$vault" "$PCM_VAULT_ROLE_CREDENTIALS")
  if [[ -z "$env_output" ]]; then
    _error "Failed to generate remote env for vault '${vault}'"
    exit 1
  fi

  echo "$env_output"
}

# ---------------------------------------------------------------------------
# pcm update
# ---------------------------------------------------------------------------

cmd_update() {
  _debug "Updating pcm from ${PCM_HOME}"
  if [[ ! -d "${PCM_HOME}/.git" ]]; then
    _error "PCM_HOME (${PCM_HOME}) is not a git repo — cannot update"
    exit 1
  fi
  git -C "$PCM_HOME" pull
  echo "pcm updated"
}

# ---------------------------------------------------------------------------
# pcm help
# ---------------------------------------------------------------------------

cmd_help() {
  cat <<'EOF'
pcm — Personal Credentials Manager

Usage: pcm [--debug] <command> [args...]

Commands:
  get [flags] <ref> [VAR]       Read a single credential (ref = item/field)
  get <credential>              Read all fields for a credential (from .pcm.yml)
    -w                            from workspace vault
    -p                            from personal vault
    -c                            from credentials vault
    --from <vault>                from a named vault
  vault                         Vault management (list, show, create)
  credentials                   Credential configuration (list, show)
  config                        Show effective configuration
  list                          List items in workspace vault (JSON)
  token                         SA token management (get, clear, list)
  remote-env                    Output backend-specific env exports for remote hosts
  update                        Update pcm (git pull)
  help                          Show this help

Configuration (unified .pcm.yml schema, merged in order):
  ~/.config/pcm/conf.d/*.yml      Global config fragments
  .pcm.yml                        Project/space-local (walked up from $PWD)

Env var overrides:
  PCM_VAULT_ROLE_WORKSPACE    Override workspace vault role
  PCM_VAULT_ROLE_PERSONAL     Override personal vault role
  PCM_VAULT_ROLE_CREDENTIALS  Override credentials vault role
  PCM_DEBUG                   Enable debug output (set to any value)

Run 'pcm <command>' for subcommand help.
EOF
}

# ---------------------------------------------------------------------------
# Main dispatch
# ---------------------------------------------------------------------------

# Use pre-parsed args (--debug already consumed at top)
set -- "${_PCM_ARGS[@]}"

command="${1:-help}"
shift 2>/dev/null || true

case "$command" in
  get)         cmd_get "$@" ;;
  vault)       cmd_vault "$@" ;;
  credentials) cmd_credentials "$@" ;;
  tools)       cmd_credentials "$@" ;;  # backward compat alias
  config)      cmd_config ;;
  list)        cmd_list ;;
  token)       cmd_token "$@" ;;
  remote-env)  cmd_remote_env ;;
  update)      cmd_update ;;
  help)        cmd_help ;;
  *)
    _error "Unknown command: $command"
    cmd_help
    exit 1
    ;;
esac
