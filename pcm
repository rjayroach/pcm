#!/usr/bin/env bash
set -euo pipefail

# pcm — Personal Credentials Manager
#
# A backend-agnostic credential manager. Reads PCM_VAULT from the environment
# to determine which vault to operate on. Backend plugins provide the actual
# implementation (1Password, Bitwarden, etc).
#
# Env vars:
#   PCM_VAULT              — vault to operate on (required for most commands)
#   PCM_BACKEND            — backend provider (default: op)
#   PCM_CREDENTIALS_VAULT  — vault storing SA tokens (default: Private)

# Resolve install location (follow symlinks to find the repo)
PCM_HOME="$(dirname "$(readlink -f "$0")")"
PCM_CONFIG="${HOME}/.config/pcm/config"
PCM_DEBUG="${PCM_DEBUG:-}"

# ---------------------------------------------------------------------------
# Internal helpers
# ---------------------------------------------------------------------------

_debug() {
  [[ -n "$PCM_DEBUG" ]] && echo "[pcm] $*" >&2 || true
}

_error() {
  echo "pcm: $*" >&2
}

_require_vault() {
  if [[ -z "${PCM_VAULT:-}" ]]; then
    _error "PCM_VAULT is not set — cd into a space directory or export PCM_VAULT"
    exit 1
  fi
}

# ---------------------------------------------------------------------------
# Load config and backend
# ---------------------------------------------------------------------------

# Load config file if present
if [[ -f "$PCM_CONFIG" ]]; then
  _debug "Loading config from $PCM_CONFIG"
  source "$PCM_CONFIG"
fi

# Resolve backend (env > config > default)
PCM_BACKEND="${PCM_BACKEND:-op}"
PCM_CREDENTIALS_VAULT="${PCM_CREDENTIALS_VAULT:-Private}"

# Load backend plugin
_backend_file="${PCM_HOME}/lib/${PCM_BACKEND}.sh"
if [[ ! -f "$_backend_file" ]]; then
  _error "Backend '${PCM_BACKEND}' not found at ${_backend_file}"
  _error "Available backends:"
  for f in "${PCM_HOME}"/lib/*.sh; do
    [[ -f "$f" ]] && _error "  $(basename "$f" .sh)"
  done
  exit 1
fi

_debug "Loading backend: ${PCM_BACKEND} from ${_backend_file}"
source "$_backend_file"

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_vault() {
  _require_vault
  echo "$PCM_VAULT"
}

cmd_env() {
  local ref="${1:-}"
  local var="${2:-}"

  if [[ -z "$ref" ]]; then
    _error "Usage: pcm env <service/field> [VAR_NAME]"
    exit 1
  fi

  _require_vault
  _debug "Reading ${ref} from vault ${PCM_VAULT}"

  local value
  value=$(_pcm_read "$PCM_VAULT" "$ref")
  if [[ -z "$value" ]]; then
    _error "Failed to read ${ref} from vault ${PCM_VAULT}"
    exit 1
  fi

  if [[ -n "$var" ]]; then
    # When called with VAR_NAME, output an export statement
    # Caller can eval: eval "$(pcm env github/token GH_TOKEN)"
    echo "export ${var}='${value}'"
  else
    echo "$value"
  fi
}

cmd_list() {
  _require_vault
  _debug "Listing items in vault ${PCM_VAULT}"
  _pcm_list "$PCM_VAULT"
}

cmd_token() {
  _require_vault
  _debug "Fetching SA token for vault ${PCM_VAULT}"

  local token=""
  local keychain_key="pcm-sa-token-${PCM_VAULT}"

  # Try macOS Keychain first
  if command -v security >/dev/null 2>&1; then
    token=$(security find-generic-password -a "$USER" -s "$keychain_key" -w 2>/dev/null || true)
    if [[ -n "$token" ]]; then
      _debug "SA token found in keychain"
      echo "$token"
      return 0
    fi
  fi

  # Fetch from backend and cache
  token=$(_pcm_sa_token "$PCM_VAULT" "$PCM_CREDENTIALS_VAULT")
  if [[ -z "$token" ]]; then
    _error "Failed to read SA token for vault '${PCM_VAULT}'"
    exit 1
  fi

  # Cache in keychain if available
  if command -v security >/dev/null 2>&1; then
    security add-generic-password -a "$USER" -s "$keychain_key" -w "$token" 2>/dev/null || true
    _debug "SA token cached in keychain"
  fi

  echo "$token"
}

cmd_update() {
  _debug "Updating pcm from ${PCM_HOME}"
  if [[ ! -d "${PCM_HOME}/.git" ]]; then
    _error "PCM_HOME (${PCM_HOME}) is not a git repo — cannot update"
    exit 1
  fi
  git -C "$PCM_HOME" pull
  echo "pcm updated"
}

cmd_help() {
  cat <<'EOF'
pcm — Personal Credentials Manager

Usage: pcm [--debug] <command> [args...]

Commands:
  vault                         Show current vault name
  env <service/field>           Echo a secret value
  env <service/field> VAR_NAME  Output export statement for eval
  list                          List items in current vault (JSON)
  token                         Get SA token for current vault (keychain cached)
  update                        Update pcm (git pull)
  help                          Show this help

Environment:
  PCM_VAULT              Vault to operate on (set via mise/.mise.toml)
  PCM_BACKEND            Backend provider (default: op)
  PCM_CREDENTIALS_VAULT  Vault storing SA tokens (default: Private)
  PCM_DEBUG              Enable debug output (set to any value)
EOF
}

# ---------------------------------------------------------------------------
# Main dispatch
# ---------------------------------------------------------------------------

# Handle --debug flag
if [[ "${1:-}" == "--debug" ]]; then
  PCM_DEBUG=1
  shift
fi

command="${1:-help}"
shift 2>/dev/null || true

case "$command" in
  vault)  cmd_vault ;;
  env)    cmd_env "$@" ;;
  list)   cmd_list ;;
  token)  cmd_token ;;
  update) cmd_update ;;
  help)   cmd_help ;;
  *)
    _error "Unknown command: $command"
    cmd_help
    exit 1
    ;;
esac
